<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="649.0" prefWidth="600.0" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/16" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.EditAppointmentController">
    <GridPane layoutX="98.0" layoutY="95.0" prefHeight="472.0" prefWidth="410.0">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" maxWidth="197.0" minWidth="10.0" prefWidth="150.0"/>
            <ColumnConstraints hgrow="SOMETIMES" maxWidth="269.0" minWidth="10.0" prefWidth="257.0"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
        </rowConstraints>
        <TextField fx:id="titleBox" prefHeight="25.0" prefWidth="149.0" GridPane.columnIndex="1"/>
        <Label text="Title"/>
        <Label text="Description" GridPane.rowIndex="1"/>
        <TextField fx:id="descriptionBox" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <TextField fx:id="locationBox" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <Label text="Location" GridPane.rowIndex="2"/>
        <Label text="Contact" GridPane.rowIndex="6"/>
        <Label text="Type" GridPane.rowIndex="3"/>
        <Label text="Start" GridPane.rowIndex="7"/>
        <Label text="End" GridPane.rowIndex="9"/>
        <Label text="Customer" GridPane.rowIndex="5"/>
        <DatePicker fx:id="startDatePicker" editable="false" onAction="#startDatePicked" prefHeight="25.0"
                    prefWidth="170.0" GridPane.columnIndex="1" GridPane.rowIndex="7"/>
        <DatePicker fx:id="endDatePicker" editable="false" prefHeight="25.0" prefWidth="170.0"
                    GridPane.columnIndex="1" GridPane.rowIndex="9"/>
        <ComboBox fx:id="customerComboBox" prefHeight="25.0" prefWidth="200.0" promptText="Select Customer"
                  GridPane.columnIndex="1" GridPane.rowIndex="5"/>
        <ComboBox fx:id="contactComboBox" prefHeight="25.0" prefWidth="200.0" promptText="Select Contact"
                  GridPane.columnIndex="1" GridPane.rowIndex="6"/>
        <HBox prefHeight="100.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="8">
            <ComboBox fx:id="startHourComboBox" prefHeight="25.0" prefWidth="80.0" promptText="Hour"/>
            <ComboBox fx:id="startMinuteComboBox" prefHeight="25.0" prefWidth="80.0" promptText="Minute"/>
        </HBox>
        <HBox prefHeight="100.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="10">
            <ComboBox fx:id="endHourComboBox" prefHeight="25.0" prefWidth="80.0" promptText="Hour"/>
            <ComboBox fx:id="endMinuteComboBox" prefHeight="25.0" prefWidth="80.0" promptText="Minute"/>
        </HBox>
        <TextField fx:id="typeBox" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <Label text="User" GridPane.rowIndex="4"/>
        <ComboBox fx:id="userComboBox" prefHeight="25.0" prefWidth="200.0" promptText="Select User"
                  GridPane.columnIndex="1" GridPane.rowIndex="4"/>
    </GridPane>
    <Label alignment="CENTER" layoutX="100.0" layoutY="29.0" prefWidth="400.0" styleClass="title-label" text="Edit Appointment"/>
    <Button layoutX="132.0" layoutY="562.0" mnemonicParsing="false" onAction="#saveButtonClicked" prefHeight="49.0"
            prefWidth="109.0" styleClass="btn-primary" text="Update"/>
    <Button layoutX="376.0" layoutY="562.0" mnemonicParsing="false" onAction="#resetButtonClicked" prefHeight="49.0"
            prefWidth="98.0" text="Reset"/>
    <Button layoutX="14.0" layoutY="17.0" mnemonicParsing="false" onAction="#backButtonClicked" text="Back"/>
    <Button layoutX="500.0" layoutY="17.0" mnemonicParsing="false" onAction="#refreshButtonClicked" text="Refresh"/>
</AnchorPane>
