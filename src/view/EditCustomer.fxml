<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/16" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.EditCustomerController">
    <GridPane layoutX="96.0" layoutY="95.0" prefHeight="267.0" prefWidth="406.0">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" maxWidth="197.0" minWidth="10.0" prefWidth="150.0"/>
            <ColumnConstraints hgrow="SOMETIMES" maxWidth="269.0" minWidth="10.0" prefWidth="257.0"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
        </rowConstraints>
        <TextField fx:id="nameBox" prefHeight="25.0" prefWidth="149.0" GridPane.columnIndex="1"/>
        <Label text="Name"/>
        <Label text="Address" GridPane.rowIndex="1"/>
        <TextField fx:id="addressBox" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <TextField fx:id="postalCodeBox" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <Label text="Postal Code" GridPane.rowIndex="2"/>
        <Label text="Country" GridPane.rowIndex="5"/>
        <Label text="Phone Number" GridPane.rowIndex="3"/>
        <Label text="Division" GridPane.rowIndex="4"/>
        <ComboBox fx:id="divisionComboBox" onAction="#divisionSelected" prefHeight="25.0" prefWidth="200.0"
                  promptText="Select Division" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        <TextField fx:id="phoneNumberBox" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <TextField fx:id="countryBox" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
    </GridPane>
    <Label alignment="CENTER" layoutX="100.0" layoutY="29.0" prefWidth="400.0" styleClass="title-label" text="Edit Customer"/>
    <Button layoutX="134.0" layoutY="419.0" mnemonicParsing="false" onAction="#updateButtonClicked" prefHeight="49.0"
            prefWidth="109.0" styleClass="btn-primary" text="Update"/>
    <Button layoutX="369.0" layoutY="419.0" mnemonicParsing="false" onAction="#resetButtonClicked" prefHeight="49.0"
            prefWidth="98.0" text="Reset"/>
    <Button layoutX="14.0" layoutY="17.0" mnemonicParsing="false" onAction="#backButtonClicked" text="Back"/>
    <Button layoutX="500.0" layoutY="17.0" mnemonicParsing="false" onAction="#refreshButtonClicked" text="Refresh"/>
</AnchorPane>
