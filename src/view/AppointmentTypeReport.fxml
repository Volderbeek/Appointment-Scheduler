<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!--suppress JavaFxUnresolvedFxIdReference -->
<AnchorPane prefHeight="400.0" prefWidth="600.0" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/16" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.AppointmentTypeReportController">
    <GridPane layoutX="53.0" layoutY="121.0" prefHeight="238.0" prefWidth="221.0">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
        </rowConstraints>
        <RadioButton mnemonicParsing="false" onAction="#janToggleSelected" text="January">
            <toggleGroup>
                <ToggleGroup fx:id="monthToggleGroup"/>
            </toggleGroup>
        </RadioButton>
        <RadioButton fx:id="febToggle" mnemonicParsing="false" onAction="#febToggleSelected" text="February"
                     toggleGroup="$monthToggleGroup" GridPane.rowIndex="1"/>
        <RadioButton fx:id="marToggle" mnemonicParsing="false" onAction="#marToggleSelected" text="March"
                     toggleGroup="$monthToggleGroup" GridPane.rowIndex="2"/>
        <RadioButton fx:id="aprToggle" mnemonicParsing="false" onAction="#aprToggleSelected" text="April"
                     toggleGroup="$monthToggleGroup" GridPane.rowIndex="3"/>
        <RadioButton fx:id="mayToggle" mnemonicParsing="false" onAction="#mayToggleSelected" text="May"
                     toggleGroup="$monthToggleGroup" GridPane.rowIndex="4"/>
        <RadioButton fx:id="junToggle" mnemonicParsing="false" onAction="#junToggleSelected" text="June"
                     toggleGroup="$monthToggleGroup" GridPane.rowIndex="5"/>
        <RadioButton fx:id="julToggle" mnemonicParsing="false" onAction="#julToggleSelected" text="July"
                     toggleGroup="$monthToggleGroup" GridPane.columnIndex="1"/>
        <RadioButton fx:id="augToggle" mnemonicParsing="false" onAction="#augToggleSelected" text="August"
                     toggleGroup="$monthToggleGroup" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <RadioButton fx:id="sepToggle" mnemonicParsing="false" onAction="#sepToggleSelected" text="September"
                     toggleGroup="$monthToggleGroup" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <RadioButton fx:id="octToggle" mnemonicParsing="false" onAction="#octToggleSelected" text="October"
                     toggleGroup="$monthToggleGroup" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <RadioButton fx:id="novToggle" mnemonicParsing="false" onAction="#novToggleSelected" text="November"
                     toggleGroup="$monthToggleGroup" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        <RadioButton fx:id="decToggle" mnemonicParsing="false" onAction="#decToggleSelected" text="December"
                     toggleGroup="$monthToggleGroup" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
    </GridPane>
    <TableView fx:id="typeReportTable" layoutX="300.0" layoutY="127.0" prefHeight="238.0" prefWidth="247.0">
      <columns>
          <TableColumn fx:id="typeReportColumn" prefWidth="166.0" text="Appointment Type"/>
          <TableColumn fx:id="countColumn" prefWidth="74.0" text="Count"/>
      </columns>
    </TableView>
    <Label alignment="CENTER" layoutX="50.0" layoutY="54.0" prefWidth="500.0" styleClass="title-label" text="Appointment Type Report"/>
    <Button layoutX="14.0" layoutY="14.0" mnemonicParsing="false" onAction="#backButtonClicked" text="Back"/>
</AnchorPane>
